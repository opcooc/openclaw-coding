<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>下属考核 - 华规绩效考评系统</title>
    <script src="https://cdn.tailwindcss.com">
        function switchSubordinate(card, name, role, score = 0) {
            document.querySelectorAll('.subordinate-card').forEach(c => {
                c.classList.remove('bg-blue-50', 'border-blue-500');
                c.classList.add('bg-gray-50', 'border-gray-200');
            });
            card.classList.remove('bg-gray-50', 'border-gray-200');
            card.classList.add('bg-blue-50', 'border-blue-500');
            document.getElementById('currentSubordinate').textContent = name;
            document.getElementById('currentRole').textContent = role;
            document.getElementById('evalName').textContent = name;
            document.getElementById('evalRole').textContent = role;
            document.querySelectorAll('.task-score').forEach(i => i.value = 0);
            document.querySelectorAll('.ability-supervisor').forEach(i => i.value = 0);
            document.querySelectorAll('.ability-manager').forEach(i => i.value = 0);
            document.getElementById('taskTotal').textContent = '0.0';
            document.getElementById('abilityTotal').textContent = '0.0';
            document.getElementById('totalScore').textContent = '0.0';
            document.getElementById('gradeLevel').textContent = '-';
            
            // Update card display for all subordinates
            document.querySelectorAll('.subordinate-card').forEach(c => {
                const isGraded = c.dataset.graded === 'true';
                const cardScore = parseFloat(c.dataset.score) || 0;
                const scoreDisplay = c.querySelector('.text-right');
                if (c === card) {
                    // Selected card
                    if (isGraded) {
                        scoreDisplay.innerHTML = '<p class="text-xs text-green-600 font-medium">已打分</p><p class="text-lg font-bold text-blue-600">' + cardScore + '</p>';
                    } else {
                        scoreDisplay.innerHTML = '<p class="text-xs text-gray-400">未打分</p><p class="text-lg font-bold text-gray-400">-</p>';
                    }
                } else {
                    // Other cards
                    const isSelected = c.classList.contains('border-blue-500');
                    if (isGraded) {
                        scoreDisplay.innerHTML = '<p class="text-xs text-green-600 font-medium">已打分</p><p class="text-lg font-bold text-blue-600">' + cardScore + '</p>';
                    } else {
                        scoreDisplay.innerHTML = '<p class="text-xs text-gray-400">未打分</p><p class="text-lg font-bold text-gray-400">-</p>';
                    }
                }
            });
        });
            card.classList.remove('bg-gray-50', 'border-gray-200');
            card.classList.add('bg-blue-50', 'border-blue-500');
            document.getElementById('currentSubordinate').textContent = name;
            document.getElementById('currentRole').textContent = role;
            document.getElementById('evalName').textContent = name;
            document.getElementById('evalRole').textContent = role;
            document.querySelectorAll('.task-score').forEach(i => i.value = 0);
            document.querySelectorAll('.ability-supervisor').forEach(i => i.value = 0);
            document.querySelectorAll('.ability-manager').forEach(i => i.value = 0);
            document.getElementById('taskTotal').textContent = '0.0';
            document.getElementById('abilityTotal').textContent = '0.0';
            document.getElementById('totalScore').textContent = '0.0';
            document.getElementById('gradeLevel').textContent = '-';
        }
    </script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-gray-50 min-h-screen">
    <div class="flex h-screen">
        <aside class="w-64 bg-blue-700 text-white flex-shrink-0">
            <div class="p-4 mx-3 mb-2 mt-4"><img src="../images/huagui-logo.png?v=20260417" alt="华规软件" class="w-full h-auto"></div>
            <nav class="mt-2">
                <a href="02-workbench.html" class="flex items-center px-6 py-3 hover:bg-blue-600 transition-colors"><i class="fas fa-home w-6"></i><span>工作台</span></a>
                <a href="03-task-submission.html" class="flex items-center px-6 py-3 hover:bg-blue-600 transition-colors"><i class="fas fa-edit w-6"></i><span>任务填报</span></a>
                <a href="08-subordinate-evaluation.html" class="flex items-center px-6 py-3 bg-blue-600 border-l-4 border-white"><i class="fas fa-users w-6"></i><span>下属考核</span></a>
                <a href="07-report-analysis.html" class="flex items-center px-6 py-3 hover:bg-blue-600 transition-colors"><i class="fas fa-file-alt w-6"></i><span>报表中心</span></a>
                <a href="06-admin-config.html" class="flex items-center px-6 py-3 hover:bg-blue-600 transition-colors"><i class="fas fa-cog w-6"></i><span>系统配置</span></a>
                <a href="09-user-management.html" class="flex items-center px-6 py-3 hover:bg-blue-600 transition-colors"><i class="fas fa-user-cog w-6"></i><span>用户管理</span></a>
                <a href="11-org-structure.html" class="flex items-center px-6 py-3 hover:bg-blue-600 transition-colors"><i class="fas fa-sitemap w-6"></i><span>组织关系</span></a>
            </nav>
        </aside>
        <div class="flex-1 flex flex-col overflow-hidden">
            <header class="bg-white shadow-sm border-b px-6 py-4">
                <div class="flex justify-between items-center">
                    <h2 class="text-2xl font-semibold text-gray-800">下属考核</h2>
                    <div class="flex items-center space-x-4">
                        <span class="text-gray-600">考评人：张三（技术主管）</span>
                        <a href="01-login.html" class="text-gray-500 hover:text-red-600"><i class="fas fa-sign-out-alt"></i><span class="ml-1">退出</span></a>
                    </div>
                </div>
            </header>
            <main class="flex-1 overflow-y-auto p-6">
                <div class="max-w-6xl mx-auto">
                    <!-- Tab 切换 -->
                    <div class="bg-white rounded-lg shadow mb-6">
                        <div class="border-b">
                            <nav class="flex space-x-4 px-4">
                                <button class="px-4 py-3 border-b-2 border-blue-500 text-blue-600 font-medium" onclick="switchTab('audit')">
                                    <i class="fas fa-clipboard-check mr-2"></i>任务审核
                                </button>
                                <button class="px-4 py-3 border-b-2 border-transparent text-gray-500 hover:text-gray-700" onclick="switchTab('evaluate')">
                                    <i class="fas fa-star mr-2"></i>考核打分
                                </button>
                            </nav>
                        </div>
                    </div>

                    <!-- 任务审核 Tab -->
                    <div id="auditTab" class="space-y-6">
                        <!-- 下属 1：李晓明 -->
                        <div class="bg-white rounded-lg shadow">
                            <div class="bg-gray-50 px-6 py-4 border-b">
                                <div class="flex items-center justify-between">
                                    <div class="flex items-center">
                                        <div class="w-10 h-10 bg-blue-600 rounded-full flex items-center justify-center text-white font-bold mr-3">李</div>
                                        <div>
                                            <h3 class="text-lg font-semibold text-gray-800">李晓明</h3>
                                            <p class="text-sm text-gray-500">高级软件工程师 | 研发中心</p>
                                        </div>
                                    </div>
                                    <div class="text-right">
                                        <span class="px-3 py-1 bg-yellow-100 text-yellow-700 rounded-full text-sm">待审核任务：3 个</span>
                                    </div>
                                </div>
                            </div>
                            <div class="p-6">
                                <table class="w-full">
                                    <thead class="bg-gray-50">
                                        <tr>
                                            <th class="text-left py-3 px-4 text-sm font-medium text-gray-700">序号</th>
